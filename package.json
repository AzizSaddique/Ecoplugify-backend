{
  "name": "ecoplugify-backend",
  "version": "1.0.0",
  "description": "Production-grade IoT backend for Ecoplugify",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "migrate:readings:dry-run": "node scripts/migrate-reading-energy-deltas.js",
    "migrate:readings:apply": "node scripts/migrate-reading-energy-deltas.js --apply",
    "migrate:readings:rollback": "node scripts/migrate-reading-energy-deltas.js --rollback"
  },
  "keywords": [
    "IoT",
    "MQTT",
    "React Native"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bullmq": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.0.0",
    "express-validator": "^7.0.0",
    "firebase-admin": "^12.0.0",
    "helmet": "^7.0.0",
    "joi": "^17.11.0",
    "mongodb": "^7.2.0",
    "mongoose": "^7.5.0",
    "mqtt": "^5.0.0",
    "redis": "^4.6.10",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.1"
  }
}
